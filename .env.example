# ============================================================================
# ATOM Platform — единый файл конфигурации для backend (Django) и frontend (Vite)
# Скопируй этот файл в .env (cp .env.example .env) и заполни значения.
# docker-compose.yml передаёт этот файл и backend-, и frontend-контейнеру,
# каждый сервис сам берёт только нужные ему переменные.
# ============================================================================

# --------------------------- DJANGO / BACKEND ------------------------------

# Секретный ключ Django — используется для подписи сессий, токенов и т.д.
# Получить: сгенерировать самому длинную случайную строку, например командой
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# НЕЛЬЗЯ оставлять значение по умолчанию в продакшене.
DJANGO_SECRET_KEY=insecure-dev-key-change-me

# Режим отладки Django. True — для разработки (подробные страницы ошибок),
# False — обязательно для продакшена.
DEBUG=True

# Список доменов/IP, с которых разрешено обращаться к Django (через запятую).
# Для локальной разработки можно оставить как есть.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Список источников (origin), которым разрешено делать CORS-запросы к API
# (адрес, с которого фронтенд отдаётся пользователю в браузере).
CORS_ALLOWED_ORIGINS=http://localhost

# Адрес фронтенда, на который Django редиректит после успешного
# OAuth-логина через Google/GitHub (social-auth-app-django).
FRONTEND_URL=http://localhost

# Строка подключения к PostgreSQL вида postgres://user:password@host:port/dbname.
# Для docker-compose можно оставить как есть — значения совпадают
# с POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB в docker-compose.yml.
DATABASE_URL=postgres://atm:atm@postgres:5432/atm

# Адрес Redis — используется и как кэш Django, и как брокер Celery.
# Для docker-compose можно оставить как есть.
REDIS_URL=redis://redis:6379/0

# --- OAuth: Google ---
# Получить: console.cloud.google.com → APIs & Services → Credentials →
#   Create Credentials → OAuth client ID → тип "Web application".
#   Authorized redirect URI: http://localhost/api/auth/social/complete/google-oauth2/
# Если оставить пустыми — кнопка "Войти через Google" будет вести на бэкенд
# и корректно покажет ошибку, остальной сайт не сломается.
GOOGLE_OAUTH2_KEY=
GOOGLE_OAUTH2_SECRET=

# --- OAuth: GitHub ---
# Получить: github.com/settings/developers → OAuth Apps → New OAuth App.
#   Authorization callback URL: http://localhost/api/auth/social/complete/github/
GITHUB_OAUTH2_KEY=
GITHUB_OAUTH2_SECRET=

# --------------------------- REACT / FRONTEND (Vite) ------------------------
# Переменные ниже обязаны начинаться с VITE_ — иначе Vite не передаст их
# в код фронтенда (это требование самого Vite, а не наша условность).

# Базовый адрес REST API, который дёргает фронтенд из браузера.
# /api подходит, когда фронтенд и backend идут через общий nginx-gateway
# (как в docker-compose.yml) — относительный путь резолвится в адрес
# текущего сайта (http://localhost:8080/api).
VITE_API_BASE_URL=/api

# Адрес backend-контейнера, на который Vite dev-сервер проксирует /api
# при локальной разработке (см. server.proxy в frontend/vite.config.js).
VITE_API_PROXY_TARGET=http://backend:8000

# Ссылка на GitHub-репозиторий с исходным кодом языка ATOM (компилятор) —
# на неё ведёт кнопка "Исходный код на GitHub" на главной странице сайта.
# Если оставить пустым — кнопка на главной просто не показывается.
VITE_GITHUB_REPO_URL=
